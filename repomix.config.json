{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": true
  },
  "include": [
    "**/*"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "repomix-output.*",
      "*.repomix-output.*",
      ".repomixignore",
      "**/*.pdf",
      "scratch/**/*"
    ]
  }
}
