{
    "_comment": "SMOKE variant of paper_comparison_irregular_freefem_divs.json — same physics and method, but N_ref=40 (partition [80,40]) and convergence_partitions=[10,20] so the pipeline runs in minutes for plumbing verification before launching the full multi-hour sweep. Numerical slopes from only 2 points are not diagnostic; this exists strictly to confirm the wall_divisions='freefem' mesh, comparison_runs, HDF5 emit, and the plotter all succeed end-to-end. For the actual convergence study use paper_comparison_irregular_freefem_divs.json (N_ref=200, partitions [10,20,40,80,100]).",
    "Re": 500.0,
    "c_in": 0.5,
    "mesh_generator": "UNSTRUCTURED",
    "wall_divisions": "freefem",
    "k_convergence_list": [
        1
    ],
    "comparison_runs": [
        { "k_velocity": 1, "k_pressure": 1, "method": "ASGS" },
        { "k_velocity": 2, "k_pressure": 2, "method": "ASGS" },
        { "k_velocity": 2, "k_pressure": 1, "method": "Galerkin", "porosity_order": 1 }
    ],
    "element_pairs": [
        [
            1,
            1
        ],
        [
            2,
            2
        ]
    ],
    "physical_properties": {
        "nu": 0.002,
        "sigma_linear": 0.30,
        "sigma_nonlinear": 1.75,
        "h_floor_weight": 0.0,
        "eps_val": 1e-7,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": 1.0,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [
            0.0,
            2.0,
            0.0,
            1.0
        ]
    },
    "outlet_truncation_delta": 0.0,
    "interpolate_solution_to_coarser_meshes": false,
    "numerical_method": {
        "viscous_operator_type": "SymmetricGradient",
        "stabilization": {
            "method": [
                "ASGS"
            ]
        },
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "mesh": {
            "partition": [
                80,
                40
            ],
            "convergence_partitions": [
                10,
                20
            ],
            "element_type": "TRI"
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "xtol": 1e-11,
            "ftol": 1e-11,
            "stagnation_noise_floor": 1e-5,
            "max_increases": 3,
            "linesearch_alpha_min": 1e-10,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "max_linesearch_iterations": 25,
            "linesearch_contraction_factor": 0.5
        }
    },
    "output": {
        "directory": "results",
        "basename": "cocquet_irr_ffd_smoke"
    }
}
