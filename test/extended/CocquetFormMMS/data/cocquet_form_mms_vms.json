{
  "mms_dynamic_budget": {
    "newton_re_iterations": 150
  },
  "_comment": "VMS equal-order stabilized triangles (P1/P1 + P2/P2, ASGS+OSGS) on the Cocquet formulation (SymmetricGradient viscous + full Forchheimer-Ergun reaction sigma=a(alpha)+b(alpha)|u|, Cocquet coefficients sigma_linear=0.3/sigma_nonlinear=1.75). Definitive (Re,alpha) MMS convergence study. Da is held at 1.0: under fixed Forchheimer coefficients Da is a no-op (run_test.jl only reads Da in the Constant_Sigma branch), so the porosity sweep alpha_0=[0.5,0.1] supplies the effective-Da variation through the collective linear+nonlinear drag. Re=[1,1e5] spans the viscous and convection-dominated regimes. Meshes capped at 160. Companion: cocquet_form_mms_taylorhood.json (the Cocquet et al. element, Galerkin Taylor-Hood P2/P1).",
  "erase_past_results": true,
  "epsilon_pert": [
    1.0
  ],
  "max_n_pert": 5,
  "mms_verification_enabled": true,
  "mms_tau_err": 0.0001,
  "h5_filename": "cocquet_form_mms_vms.h5",
  "physical_properties": {
    "Re": [
      1.0,
      100000.0
    ],
    "Da": [
      1.0
    ],
    "physical_epsilon": [
      0.0
    ],
    "numerical_epsilon_coefficient": [
      0.0001
    ],
    "reaction_model": "Forchheimer_Ergun",
    "sigma_linear": 0.3,
    "sigma_nonlinear": 1.75,
    "f_x": 0.0,
    "f_y": 0.0
  },
  "domain": {
    "alpha_0": [
      0.5,
      0.1
    ],
    "r_1": 0.2,
    "r_2": 0.4,
    "bounding_box": [
      -0.5,
      0.5,
      -0.5,
      0.5
    ]
  },
  "numerical_method": {
    "viscous_operator_type": "SymmetricGradient",
    "element_spaces": {
      "k_velocity": [
        1,
        2
      ],
      "k_pressure": [
        1,
        2
      ],
      "equal_order_only": true
    },
    "mesh": {
      "partition": [
        10,
        10
      ],
      "convergence_partitions": [
        10,
        20,
        40,
        80,
        160,
        320
      ],
      "element_type": [
        "TRI"
      ]
    },
    "solver": {
      "picard_iterations": 15,
      "newton_iterations": 150,
      "noise_floor_success_max_ftol_multiple": 10.0,
      "xtol": 1e-12,
      "ftol": 1e-12,
      "eps_tol_momentum": 1e-09,
      "stagnation_noise_floor": 1e-05,
      "linesearch_alpha_min": 0.0001,
      "max_linesearch_iterations": 25,
      "linesearch_contraction_factor": 0.5,
      "max_increases": 3,
      "divergence_merit_factor": 1.05,
      "armijo_c1": 0.0001,
      "newton_residual_divergence_patience": 2,
      "pingpong_enabled": true,
      "pingpong_max_swaps": 4,
      "pingpong_picard_gain_orders": 1.5,
      "osgs_jfnk_enabled": true
    },
    "stabilization": {
      "method": [
        "ASGS",
        "OSGS"
      ]
    }
  },
  "output": {
    "directory": "test/extended/CocquetFormMMS/results",
    "basename": "cocquet_form_mms_vms"
  },
  "write_vtk": false,
  "trace_convergence_norms": true
