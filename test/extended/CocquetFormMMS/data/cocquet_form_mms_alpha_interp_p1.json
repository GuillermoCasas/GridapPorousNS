{
  "mms_dynamic_budget": {
    "newton_re_iterations": 150
  },
  "_comment": "Audit response R2/I07: POROSITY-INTERPOLATION ablation. Identical to the analytic VMS baseline (cocquet_form_mms_vms.json) but with numerical_method.porosity_interpolation_order=1, so the FORMULATION uses a P1 finite-element interpolant of alpha while the oracle keeps the analytic alpha (the forcing stays exact). Comparing the errors here against the analytic baseline isolates the MODEL error introduced by interpolating the porosity, testing whether it spoils convergence (the claim previously in the conclusion, softened to future work by I07). Focused on the viscous regime (Re=1) at both porosities (alpha_0=[0.5,0.1]) -- where alpha's spatial structure, and hence its interpolation error, matters most -- for the equal-order P1/P1 and P2/P2 ASGS elements. Meshes N=10..160.",
  "erase_past_results": true,
  "epsilon_pert": [
    1.0
  ],
  "max_n_pert": 5,
  "mms_verification_enabled": true,
  "mms_tau_err": 0.0001,
  "interpolation_reference": {
      "error_quadrature_degree_boost": 4,
      "verification_quadrature_degree": 20,
      "verification_rel_tol": 1e-6
  },
  "h5_filename": "cocquet_form_mms_alpha_interp_p1.h5",
  "physical_properties": {
    "Re": [
      1.0
    ],
    "Da": [
      1.0
    ],
    "physical_epsilon": [
      0.0
    ],
    "numerical_epsilon_coefficient": [
      0.0001
    ],
    "reaction_model": "Forchheimer_Ergun",
    "sigma_linear": 0.3,
    "sigma_nonlinear": 1.75,
    "f_x": 0.0,
    "f_y": 0.0
  },
  "domain": {
    "alpha_0": [
      0.5,
      0.1
    ],
    "r_1": 0.2,
    "r_2": 0.4,
    "bounding_box": [
      -0.5,
      0.5,
      -0.5,
      0.5
    ]
  },
  "numerical_method": {
    "viscous_operator_type": "SymmetricGradient",
    "porosity_interpolation_order": 1,
    "element_spaces": {
      "k_velocity": [
        1,
        2
      ],
      "k_pressure": [
        1,
        2
      ],
      "equal_order_only": true
    },
    "mesh": {
      "partition": [
        10,
        10
      ],
      "convergence_partitions": [
        10,
        20,
        40,
        80,
        160
      ],
      "element_type": [
        "TRI"
      ]
    },
    "solver": {
      "picard_iterations": 15,
      "newton_iterations": 150,
      "noise_floor_success_max_ftol_multiple": 10.0,
      "xtol": 1e-12,
      "ftol": 1e-12,
      "eps_tol_momentum": 1e-09,
      "stagnation_noise_floor": 1e-05,
      "linesearch_alpha_min": 0.0001,
      "max_linesearch_iterations": 25,
      "linesearch_contraction_factor": 0.5,
      "max_increases": 3,
      "divergence_merit_factor": 1.05,
      "armijo_c1": 0.0001,
      "newton_residual_divergence_patience": 2,
      "pingpong_enabled": true,
      "pingpong_max_swaps": 4,
      "pingpong_picard_gain_orders": 1.5
    },
    "stabilization": {
      "method": [
        "ASGS"
      ]
    }
  },
  "output": {
    "directory": "test/extended/CocquetFormMMS/results",
    "basename": "cocquet_form_mms_alpha_interp_p1"
  },
  "write_vtk": false,
  "trace_convergence_norms": true
}
