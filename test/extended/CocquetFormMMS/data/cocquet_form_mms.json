{
  "mms_dynamic_budget": {
    "newton_re_iterations": 150
  },
  "_comment": "Manufactured-solution sweep whose FORMULATION is identical to the Cocquet benchmark (SymmetricGradient viscous operator + nonlinear Forchheimer-Ergun reaction, Taylor-Hood P2/P1, ASGS), but with a known smooth exact solution and the standard radial porosity. Discriminator: if this converges optimally the Cocquet suboptimality is physical/pre-asymptotic; if it degrades, a real formulation bug is isolated. The Cocquet experiment itself is untouched. alpha_0=1.0 is the pure-NS control (sigma=0); alpha_0<1 activates the Forchheimer drag (sigma_linear/sigma_nonlinear match Cocquet).",
  "erase_past_results": true,
  "epsilon_pert": [
    1.0
  ],
  "max_n_pert": 5,
  "mms_verification_enabled": true,
  "mms_tau_err": 0.0001,
  "h5_filename": "cocquet_form_mms.h5",
  "physical_properties": {
    "Re": [
      1.0,
      100.0,
      500.0
    ],
    "Da": [
      1.0
    ],
    "physical_epsilon": [
      0.0
    ],
    "numerical_epsilon_coefficient": [
      0.0001
    ],
    "reaction_model": "Forchheimer_Ergun",
    "sigma_linear": 0.3,
    "sigma_nonlinear": 1.75,
    "f_x": 0.0,
    "f_y": 0.0
  },
  "domain": {
    "alpha_0": [
      1.0,
      0.5,
      0.05
    ],
    "r_1": 0.2,
    "r_2": 0.4,
    "bounding_box": [
      -0.5,
      0.5,
      -0.5,
      0.5
    ]
  },
  "numerical_method": {
    "viscous_operator_type": "SymmetricGradient",
    "element_spaces": {
      "k_velocity": [
        2
      ],
      "k_pressure": [
        1
      ],
      "equal_order_only": false
    },
    "mesh": {
      "partition": [
        10,
        10
      ],
      "convergence_partitions": [
        10,
        20,
        40,
        80,
        160,
        320
      ],
      "element_type": [
        "TRI"
      ]
    },
    "solver": {
      "picard_iterations": 15,
      "newton_iterations": 150,
      "noise_floor_success_max_ftol_multiple": 10.0,
      "xtol": 1e-12,
      "ftol": 1e-12,
      "eps_tol_momentum": 1e-09,
      "stagnation_noise_floor": 1e-05,
      "linesearch_alpha_min": 0.0001,
      "max_linesearch_iterations": 25,
      "linesearch_contraction_factor": 0.5,
      "max_increases": 3,
      "divergence_merit_factor": 1.05,
      "armijo_c1": 0.0001,
      "newton_residual_divergence_patience": 2,
      "pingpong_enabled": true,
      "pingpong_max_swaps": 4,
      "pingpong_picard_gain_orders": 1.5
    },
    "stabilization": {
      "method": [
        "ASGS"
      ]
    }
  },
  "output": {
    "directory": "test/extended/CocquetFormMMS/results",
    "basename": "cocquet_form_mms"
  },
  "write_vtk": false,
  "trace_convergence_norms": true
}