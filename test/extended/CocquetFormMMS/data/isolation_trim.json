{
  "_comment": "ISOLATION EXPERIMENT C (TRIM) — is REACTION-IN-THE-STABILIZATION what folds the low-α cells? Constant_Sigma (UNIFORM σ, so no heterogeneity/nonlinearity confound) at the fold regime Re=1e5, alpha_0=0.1, Da=40 (σ_c=Da·α_∞·ν/L², matched to the linear Forchheimer control's drag; sigma_linear=0.4944/nonlinear=0 only set the encoding L≈6.33). experimental_reaction_mode='standard' ⇒ ProjectResidualWithoutReactionWhenConstantSigma: the reaction σu is TRIMMED from the stabilization (kept in the Galerkin form) — i.e. the stabilized method treats the reaction the way Taylor-Hood does. Companion: isolation_full.json (same σ, reaction LEFT IN the stabilization). If TRIM converges and FULL folds ⇒ reaction-in-stabilization is the culprit (the σ̃_α coercivity collapse).",
  "erase_past_results": true,
  "epsilon_pert": [1.0],
  "max_n_pert": 5,
  "mms_verification_enabled": true,
  "mms_tau_err": 0.0001,
  "h5_filename": "isolation_trim.h5",
  "physical_properties": {
    "Re": [100000.0],
    "Da": [40.0],
    "physical_epsilon": [0.0],
    "numerical_epsilon_coefficient": [0.0001],
    "reaction_model": "Constant_Sigma",
    "sigma_linear": 0.4944,
    "sigma_nonlinear": 0.0,
    "f_x": 0.0,
    "f_y": 0.0
  },
  "domain": {
    "alpha_0": [0.1],
    "r_1": 0.2,
    "r_2": 0.4,
    "bounding_box": [-0.5, 0.5, -0.5, 0.5]
  },
  "numerical_method": {
    "viscous_operator_type": "SymmetricGradient",
    "element_spaces": {
      "k_velocity": [1],
      "k_pressure": [1],
      "equal_order_only": true
    },
    "mesh": {
      "partition": [10, 10],
      "convergence_partitions": [10, 20, 40],
      "element_type": ["TRI"]
    },
    "solver": {
      "experimental_reaction_mode": "standard",
      "picard_iterations": 15,
      "newton_iterations": 150,
      "dynamic_newton_re_iterations": 150,
      "noise_floor_success_max_ftol_multiple": 10.0,
      "xtol": 1e-12,
      "ftol": 1e-12,
      "eps_tol_momentum": 1e-09,
      "dynamic_ftol_ceiling": 0.0001,
      "dynamic_ftol_spatial_safety_factor": 0.01,
      "stagnation_noise_floor": 1e-05,
      "linesearch_alpha_min": 0.0001,
      "max_linesearch_iterations": 25,
      "linesearch_contraction_factor": 0.5,
      "max_increases": 3,
      "divergence_merit_factor": 1.05,
      "armijo_c1": 0.0001,
      "newton_residual_divergence_patience": 2,
      "pingpong_enabled": true,
      "pingpong_max_swaps": 4,
      "pingpong_picard_gain_orders": 1.5
    },
    "stabilization": {
      "method": ["ASGS"]
    }
  },
  "output": {
    "directory": "test/extended/CocquetFormMMS/results",
    "basename": "isolation_trim"
  },
  "write_vtk": false,
  "trace_convergence_norms": true
}
