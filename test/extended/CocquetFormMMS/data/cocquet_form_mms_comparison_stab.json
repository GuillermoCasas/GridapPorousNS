{
    "_comment": "Three-way comparison at Re=Da=1, alpha_0=0.5 \u2014 leg 1 of 2 (equal-order ASGS). Pairs with cocquet_form_mms_comparison_galerkin.json (pure-Galerkin Taylor-Hood) into one h5 (cocquet_form_mms_comparison.h5). Erases past results to start fresh; the Galerkin leg appends. Pressure penalty (numerical_epsilon_coefficient) is zero in both legs so the formulation matches the Cocquet paper exactly, modulo the small velocity floor used inside the Forchheimer drag (relative impact ~1e-16 at this physics regime \u2014 negligible).",
    "erase_past_results": true,
    "epsilon_pert": [
        1.0
    ],
    "max_n_pert": 5,
    "mms_verification_enabled": true,
    "mms_tau_err": 0.0001,
    "h5_filename": "cocquet_form_mms_comparison.h5",
    "physical_properties": {
        "Re": [
            1.0
        ],
        "Da": [
            1.0
        ],
        "physical_epsilon": [
            0.0
        ],
        "numerical_epsilon_coefficient": [
            0.0
        ],
        "reaction_model": "Forchheimer_Ergun",
        "sigma_linear": 0.3,
        "sigma_nonlinear": 1.75,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": [
            0.5
        ],
        "r_1": 0.2,
        "r_2": 0.4,
        "bounding_box": [
            -0.5,
            0.5,
            -0.5,
            0.5
        ]
    },
    "numerical_method": {
        "viscous_operator_type": "SymmetricGradient",
        "element_spaces": {
            "k_velocity": [
                1,
                2
            ],
            "k_pressure": [
                1,
                2
            ],
            "equal_order_only": true
        },
        "mesh": {
            "partition": [
                10,
                10
            ],
            "convergence_partitions": [
                10,
                20,
                40,
                80,
                160,
                320
            ],
            "element_type": [
                "TRI"
            ]
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "xtol": 1e-10,
            "ftol": 1e-10,
            "dynamic_ftol_ceiling": 0.0001,
            "dynamic_ftol_spatial_safety_factor": 0.01,
            "stagnation_noise_floor": 1e-05,
            "linesearch_alpha_min": 1e-10,
            "max_linesearch_iterations": 25,
            "linesearch_contraction_factor": 0.5,
            "max_increases": 3,
            "divergence_merit_factor": 1.05,
            "armijo_c1": 0.0001,
            "accelerator": {
                "type": "Anderson",
                "m": 10,
                "relaxation_factor": 0.8
            }
        },
        "stabilization": {
            "method": [
                "ASGS"
            ],
            "osgs_iterations": 15,
            "osgs_tolerance": 1e-10
        }
    },
    "output": {
        "directory": "test/extended/CocquetFormMMS/results",
        "basename": "cocquet_form_mms_comparison_stab"
    }
}