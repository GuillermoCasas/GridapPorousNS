{
    "Re": 500.0,
    "c_in": 0.5,
    "k_convergence_list": [1, 2],
    "physical_properties": {
        "nu": 0.002,
        "sigma_linear": 0.30,
        "sigma_nonlinear": 1.75,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": 1.0,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [0.0, 2.0, 0.0, 1.0]
    },
    "outlet_truncation_delta": 0.0,
    "interpolate_solution_to_coarser_meshes": false,
    "numerical_method": {
        "stabilization": {
            "method": ["ASGS", "OSGS"],
            "osgs_iterations": 30
        },
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "mesh": {
            "partition": [400, 200],
            "convergence_partitions": [10, 50, 100],
            "element_type": "TRI"
        },
        "solver": {
            "xtol": 1e-8,
            "max_increases": 3
        }
    },
    "output": {
        "directory": "results",
        "basename": "cocquet_flow"
    }
}
