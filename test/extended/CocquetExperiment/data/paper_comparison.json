{
    "_comment": "Cocquet convergence study for comparison with Cocquet et al. (2020), Figs 2-3: same physical case (Re=500, c_in=0.5, transverse porosity). STABILIZED equal-order pairs P1/P1 and P2/P2 only (the VMS method's purpose). Reference raised to N=320 (vs the paper's 200) so the coarse N in {10,20,40,80} are >=4x coarser than the reference, removing the reference-resolution contamination that otherwise depresses the superconverged velocity-L2 slope. h_floor_weight=0 (reaction-speed fix). Run: julia --project=../../.. run_convergence.jl paper_comparison.json",
    "Re": 500.0,
    "c_in": 0.5,
    "k_convergence_list": [1],
    "element_pairs": [[1, 1], [2, 2]],
    "physical_properties": {
        "nu": 0.002,
        "sigma_linear": 0.30,
        "sigma_nonlinear": 1.75,
        "h_floor_weight": 0.0,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": 1.0,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [0.0, 2.0, 0.0, 1.0]
    },
    "outlet_truncation_delta": 0.5,
    "interpolate_solution_to_coarser_meshes": false,
    "numerical_method": {
        "viscous_operator_type": "SymmetricGradient",
        "stabilization": {
            "method": ["ASGS"],
            "osgs_iterations": 15,
            "osgs_tolerance": 1e-10
        },
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "mesh": {
            "partition": [640, 320],
            "convergence_partitions": [10, 20, 40, 80],
            "element_type": "TRI"
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "xtol": 1e-11,
            "ftol": 1e-11,
            "dynamic_ftol_ceiling": 1e-4,
            "dynamic_ftol_spatial_safety_factor": 1e-2,
            "stagnation_noise_floor": 1e-5,
            "max_increases": 3,
            "linesearch_alpha_min": 1e-10,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "max_linesearch_iterations": 25,
            "linesearch_contraction_factor": 0.5,
            "accelerator": {
                "type": "Anderson",
                "m": 5,
                "relaxation_factor": 1.0
            }
        }
    },
    "output": {
        "directory": "results",
        "basename": "cocquet_paper_cmp"
    }
}
