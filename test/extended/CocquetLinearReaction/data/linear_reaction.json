{
    "_comment": "NONLINEAR-REACTION ISOLATION — IDENTICAL to CocquetExperiment/paper_comparison.json (Re=500, c_in=0.5, varying porosity, mixed BC with traction outlet, SymmetricGradient viscous, equal-order P1/P1 and P2/P2, N=200 reference over coarse N in {10,20,40,80}, h_floor_weight=0) EXCEPT sigma_nonlinear=0, which turns OFF the Forchheimer |u| nonlinear drag while keeping the linear porosity-dependent Darcy term sigma_linear*((1-a)/a)^2. This is the ONLY change vs the benchmark. If P2/P2 is unchanged, the nonlinear reaction contributes nothing to the cap (corner-dominated). Run: julia --project=../../.. run_convergence.jl linear_reaction.json",
    "Re": 500.0,
    "c_in": 0.5,
    "k_convergence_list": [
        1
    ],
    "element_pairs": [
        [
            1,
            1
        ],
        [
            2,
            2
        ]
    ],
    "physical_properties": {
        "nu": 0.002,
        "physical_epsilon": 1e-7,
        "sigma_linear": 0.30,
        "sigma_nonlinear": 0.0,
        "h_floor_weight": 0.0,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": 1.0,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [
            0.0,
            2.0,
            0.0,
            1.0
        ]
    },
    "outlet_truncation_delta": 0.0,
    "interpolate_solution_to_coarser_meshes": false,
    "numerical_method": {
        "viscous_operator_type": "SymmetricGradient",
        "stabilization": {
            "method": [
                "ASGS"
            ]
        },
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "mesh": {
            "partition": [
                400,
                200
            ],
            "convergence_partitions": [
                10,
                20,
                40,
                80
            ],
            "element_type": "TRI"
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "xtol": 1e-11,
            "ftol": 1e-11,
            "stagnation_noise_floor": 1e-5,
            "max_increases": 3,
            "linesearch_alpha_min": 1e-10,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "max_linesearch_iterations": 25,
            "linesearch_contraction_factor": 0.5
        }
    },
    "output": {
        "directory": "results",
        "basename": "cocquet_linreaction"
    }
}