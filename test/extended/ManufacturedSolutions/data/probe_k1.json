{
    "erase_past_results": true,
    "h5_filename": "probe_k1.h5",
    "epsilon_pert": [0.1],
    "max_n_pert": 5,
    "physical_properties": {
        "Re": [1e-6],
        "Da": [1e6],
        "physical_epsilon": [0.0],
        "numerical_epsilon_coefficient": [0.0001],
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": [0.5],
        "r_1": 0.2,
        "r_2": 0.4,
        "bounding_box": [-0.5, 0.5, -0.5, 0.5]
    },
    "numerical_method": {
        "viscous_operator_type": "DeviatoricSymmetric",
        "stabilization": {
            "method": ["OSGS", "ASGS"],
            "osgs_iterations": 15,
            "osgs_inner_newton_iters": 20,
            "osgs_tolerance": 1e-10,
            "osgs_projection_tolerance": 1e-10,
            "osgs_stopping_mode": "state_drift",
            "osgs_state_drift_scale": "L2_mass",
            "osgs_warmup_iterations": 2,
            "osgs_warmup_tolerance": 1e-3
        },
        "element_spaces": {
            "k_velocity": [1],
            "k_pressure": [1],
            "equal_order_only": true
        },
        "mesh": {
            "partition": [10, 10],
            "convergence_partitions": [10, 80],
            "element_type": ["QUAD"]
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "dynamic_picard_re_threshold": 1e8,
            "dynamic_picard_re_iterations": 10,
            "dynamic_picard_da_threshold": 1e8,
            "dynamic_picard_da_iterations": 10,
            "xtol": 1e-3,
            "ftol": 1e-3,
            "dynamic_ftol_ceiling": 1e-3,
            "dynamic_ftol_spatial_safety_factor": 1e-1,
            "max_increases": 3,
            "freeze_jacobian_cusp": false,
            "linesearch_alpha_min": 1e-4,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "stagnation_noise_floor": 1e-3,
            "condition_noise_floor_baseline": 1e-16,
            "condition_noise_floor_absolute_min": 1e-4,
            "condition_noise_floor_safety_factor": 10.0,
            "max_linesearch_iterations": 15,
            "linesearch_contraction_factor": 0.5,
            "run_diagnostics": false,
            "ablation_mode": "full",
            "experimental_reaction_mode": "standard",
            "accelerator": {
                "type": "Anderson",
                "m": 10,
                "relaxation_factor": 0.8
            }
        }
    },
    "output": {
        "directory": "test/long/ManufacturedSolutions/results",
        "basename": "probe_k1"
    }
}
