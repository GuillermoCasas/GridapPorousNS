{
    "erase_past_results": true,
    "epsilon_pert": [0.1],
    "max_n_pert": 5,
    "physical_properties": {
        "Re": [1e-6],
        "Da": [1e6],
        "physical_epsilon": [0.0],
        "numerical_epsilon_coefficient": [0.0001],
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": [0.5],
        "r_1": 0.2,
        "r_2": 0.4,
        "bounding_box": [-0.5, 0.5, -0.5, 0.5]
    },
    "numerical_method": {
        "stabilization": {
            "method": ["OSGS", "ASGS"],
            "osgs_iterations": 5,
            "osgs_inner_newton_iters": 20,
            "osgs_tolerance": 1e-10
        },
        "element_spaces": {
            "k_velocity": [1,2,3],
            "k_pressure": [1,2,3],
            "equal_order_only": true
        },
        "mesh": {
            "partition": [10, 10],
            "convergence_partitions": [10, 20, 40, 80, 160],
            "element_type": ["QUAD", "TRI"]
        },
        "solver": {
            "picard_iterations": 2,
            "xtol": 1e-11,
            "ftol": 1e-11,
            "dynamic_ftol_ceiling": 1e-4,
            "dynamic_ftol_spatial_safety_factor": 1e-2,
            "stagnation_noise_floor": 1e-5,
            "max_linesearch_iterations": 15,
            "linesearch_contraction_factor": 0.5,
            "max_increases": 3,
            "accelerator": {
                "type": "Anderson",
                "m": 10,
                "relaxation_factor": 0.8
            }
        }
    },
    "output": {
        "directory": "test/long/ManufacturedSolutions/results",
        "basename": "mms_small"
    }
}
