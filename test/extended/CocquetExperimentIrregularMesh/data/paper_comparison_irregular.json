{
    "_comment": "IRREGULAR-MESH flip of CocquetExperiment/paper_comparison.json. ONLY difference: mesh_generator=UNSTRUCTURED (gmsh Delaunay interior with FreeFem-style prescribed boundary divisions), to match Cocquet et al. (2020) Figs 2-3 which used FreeFem buildmesh. Same Re=500, c_in=0.5, transverse porosity, same THREE-WAY comparison (VMS P1/P1, VMS P2/P2, Cocquet Galerkin P2/P1 with P1 porosity). eps_val=1e-7 set explicitly to match the paper's eta pressure penalty, uniformly across all three runs. Reference N=200, coarse N in {10,20,40,80,100} (paper goes up to 100). Run: cd test/extended/CocquetExperimentIrregularMesh && julia --project=../../.. run_convergence.jl paper_comparison_irregular.json",
    "Re": 500.0,
    "c_in": 0.5,
    "mesh_generator": "UNSTRUCTURED",
    "k_convergence_list": [
        1
    ],
    "comparison_runs": [
        { "k_velocity": 1, "k_pressure": 1, "method": "ASGS" },
        { "k_velocity": 2, "k_pressure": 2, "method": "ASGS" },
        { "k_velocity": 2, "k_pressure": 1, "method": "Galerkin", "porosity_order": 1 }
    ],
    "element_pairs": [
        [
            1,
            1
        ],
        [
            2,
            2
        ]
    ],
    "physical_properties": {
        "nu": 0.002,
        "sigma_linear": 0.30,
        "sigma_nonlinear": 1.75,
        "h_floor_weight": 0.0,
        "eps_val": 1e-7,
        "f_x": 0.0,
        "f_y": 0.0
    },
    "domain": {
        "alpha_0": 1.0,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [
            0.0,
            2.0,
            0.0,
            1.0
        ]
    },
    "outlet_truncation_delta": 0.0,
    "interpolate_solution_to_coarser_meshes": false,
    "numerical_method": {
        "viscous_operator_type": "SymmetricGradient",
        "stabilization": {
            "method": [
                "ASGS"
            ]
        },
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "mesh": {
            "partition": [
                400,
                200
            ],
            "convergence_partitions": [
                10,
                20,
                40,
                80,
                100
            ],
            "element_type": "TRI"
        },
        "solver": {
            "picard_iterations": 2,
            "newton_iterations": 10,
            "xtol": 1e-11,
            "ftol": 1e-11,
            "dynamic_ftol_ceiling": 1e-4,
            "dynamic_ftol_spatial_safety_factor": 1e-2,
            "stagnation_noise_floor": 1e-5,
            "max_increases": 3,
            "linesearch_alpha_min": 1e-10,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "max_linesearch_iterations": 25,
            "linesearch_contraction_factor": 0.5
        }
    },
    "output": {
        "directory": "results",
        "basename": "cocquet_irr_cmp"
    }
}
