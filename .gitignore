# Ignore system specific and temporary IDE files
.DS_Store
*.DS_Store
**/.DS_Store
FETCH_HEAD
.idea/
.vscode/
.claude/

# Redundant archive: the diffable extracted sources live in files/; keep the opaque zip out of git.
docs/convergence_problems_audit/files.zip
proof_verification/files/*.zip

# Ignore compiled artifacts and test result output directories entirely
results/
**/results/
# Per-cell solver trajectory dumps are run output, not source (e.g. archived sweep baselines)
**/traces/
# Ignore generated plots and figures
*.png


# Ignore specific Gridap and Julia files
*.jl.cov
*.jl.cs
*.jl.mem
jl_*.log
*.sqlite
Manifest.toml

# Ignore per-test log folders and ad-hoc probe logs (run output, not source)
**/logs/
**/diagnostics/*.log

# Ignore generic compilation temporary files
*.tmp
*.bak
*~
*.so
*.dylib
*.dylib.*
.nra.cache

# Ignore repomix outputs
repomix-output.*
*.repomix-output.*

# LaTeX compilation intermediates (independent of location)
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.bbl
*.blg
*.bcf
*.run.xml
*.synctex(busy)
*.pdfsync
*.thm

# LaTeX build/compilation folders (e.g. build/, compilation/ in any directory)
compilation/
latex\ compilation/

# Specific compiled PDF documents (that are build outputs rather than sources)
/theory/centered_encoding/centered_encoding.pdf
/theory/osgs_algorithm/osgs_algorithm.pdf
/theory/osgs_reaction_note/osgs_reaction_note.pdf
/theory/tau_saturation_note/tau_saturation_note.pdf
/theory/pressure_recentering_note/pressure_recentering_note.pdf
/theory/paper/article.pdf
/theory/paper/supplement.pdf
/theory/paper/shared.pdf
/theory/paper/elemental_matrices_appendix.pdf
/theory/cocquet/cocquet_formulation.pdf
/theory/cocquet/cocquet_form_mms_manufactured_solution.pdf
