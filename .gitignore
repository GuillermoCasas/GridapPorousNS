# Ignore system specific and temporary IDE files
.DS_Store
*.DS_Store
**/.DS_Store
FETCH_HEAD
.idea/
.vscode/
.claude/

# Ignore compiled artifacts and test result output directories entirely
results/
**/results/

# Ignore specific Gridap and Julia files
*.jl.cov
*.jl.cs
*.jl.mem
jl_*.log
*.sqlite
Manifest.toml

# Ignore per-test log folders and ad-hoc probe logs (run output, not source)
**/logs/
**/diagnostics/*.log

# Ignore generic compilation temporary files
*.tmp
*.bak
*~
*.so
*.dylib
*.dylib.*

# Ignore repomix outputs
repomix-output.*
*.repomix-output.*

# LaTeX compilation intermediates (generic — covers any theory/*.tex build).
# .pdf is NOT in the generic list because the bibliography/source PDFs (e.g. article.pdf,
# the Cocquet reference) live alongside the .tex sources; per-file rules below ignore the
# specific build outputs we don't want tracked.
theory/*.aux
theory/*.fdb_latexmk
theory/*.fls
theory/*.log
theory/*.out
theory/*.synctex.gz
theory/*.toc

# LaTeX compilation intermediates for theory/osgs_algorithm.tex
theory/osgs_algorithm.aux
theory/osgs_algorithm.fdb_latexmk
theory/osgs_algorithm.fls
theory/osgs_algorithm.log
theory/osgs_algorithm.out
theory/osgs_algorithm.pdf
theory/osgs_algorithm.synctex.gz
theory/osgs_algorithm.toc

# LaTeX compilation intermediates for theory/cocquet_formulation.tex
theory/cocquet_formulation.aux
theory/cocquet_formulation.fdb_latexmk
theory/cocquet_formulation.fls
theory/cocquet_formulation.log
theory/cocquet_formulation.out
theory/cocquet_formulation.pdf
theory/cocquet_formulation.synctex.gz
theory/cocquet_formulation.toc

# Defensive: same artifacts at repo root if latexmk is ever run from there
/osgs_algorithm.aux
/osgs_algorithm.fdb_latexmk
/osgs_algorithm.fls
/osgs_algorithm.log
/osgs_algorithm.out
/osgs_algorithm.pdf
/osgs_algorithm.synctex.gz
/osgs_algorithm.toc
