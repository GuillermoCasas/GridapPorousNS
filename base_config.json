{
    "$schema": "./porous_ns.schema.json",
    "physical_parameters": {
        "nu": 1.0,
        "f_x": 0.0,
        "f_y": 0.0,
        "eps_val": 1e-8,
        "eps_floor": 1e-8,
        "reaction_model": "Forchheimer",
        "sigma_constant": 1.0,
        "sigma_linear": 150.0,
        "sigma_nonlinear": 1.75
    },
    "porosity_field": {
        "alpha_0": 0.4,
        "r_1": 0.2,
        "r_2": 0.5
    },
    "discretization": {
        "k_velocity": 2,
        "k_pressure": 1
    },
    "mesh": {
        "domain": [0.0, 1.0, 0.0, 1.0],
        "partition": [20, 20]
    },
    "output": {
        "directory": "results",
        "basename": "porous_ns"
    },
    "solver": {
        "picard_iterations": 5,
        "newton_iterations": 20,
        "use_linesearch": true,
        "xtol": 1e-8,
        "stagnation_tol": 1e-5,
        "max_increases": 3
    }
}
