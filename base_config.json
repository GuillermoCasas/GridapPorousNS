{
    "$schema": "./porous_ns.schema.json",
    "physical_properties": {
        "nu": 1.0,
        "f_x": 0.0,
        "f_y": 0.0,
        "eps_val": 1e-8,
        "eps_floor": 1e-8,
        "reaction_model": "Forchheimer",
        "sigma_constant": 1.0,
        "sigma_linear": 150.0,
        "sigma_nonlinear": 1.75,
        "u_base_floor_ref": 1e-4,
        "h_floor_weight": 0.1,
        "epsilon_floor": 1e-12,
        "tau_regularization_limit": 1e-12
    },
    "domain": {
        "alpha_0": 0.4,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [
            0.0,
            1.0,
            0.0,
            1.0
        ]
    },
    "numerical_method": {
        "viscous_operator_type": "DeviatoricSymmetric",
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "stabilization": {
            "method": "ASGS",
            "osgs_iterations": 3,
            "osgs_inner_newton_iters": 3,
            "osgs_tolerance": 1e-5,
            "osgs_stopping_mode": "state_drift",
            "osgs_projection_tolerance": 1e-5,
            "osgs_state_drift_scale": "Linf",
            "osgs_warmup_iterations": 2,
            "osgs_warmup_tolerance": 1e-3
        },
        "solver": {
            "picard_iterations": 5,
            "newton_iterations": 20,
            "ftol": 1e-8,
            "dynamic_ftol_ceiling": 1e-4,
            "dynamic_ftol_spatial_safety_factor": 1e-2,
            "xtol": 1e-8,
            "max_increases": 2,
            "freeze_jacobian_cusp": false,
            "linesearch_alpha_min": 1e-4,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "stagnation_noise_floor": 1e-2,
            "max_linesearch_iterations": 15,
            "linesearch_contraction_factor": 0.5,
            "run_diagnostics": false,
            "ablation_mode": "full",
            "experimental_reaction_mode": "standard",
            "accelerator": {
                "type": "None",
                "m": 5,
                "relaxation_factor": 1.0
            }
        },
        "mesh": {
            "partition": [
                20,
                20
            ],
            "convergence_partitions": [
                10,
                20,
                30
            ],
            "element_type": "QUAD"
        }
    },
    "output": {
        "directory": "results",
        "basename": "porous_ns"
    }
}