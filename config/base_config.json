{
    "$schema": "./porous_ns.schema.json",
    "physical_properties": {
        "nu": 1.0,
        "f_x": 0.0,
        "f_y": 0.0,
        "reaction_model": "Forchheimer",
        "sigma_constant": 1.0,
        "sigma_linear": 150.0,
        "sigma_nonlinear": 1.75,
        "u_base_floor_ref": 1e-4,
        "h_floor_weight": 0.1,
        "epsilon_floor": 1e-12,
        "tau_regularization_limit": 1e-12
    },
    "domain": {
        "alpha_0": 0.4,
        "r_1": 0.2,
        "r_2": 0.5,
        "bounding_box": [
            0.0,
            1.0,
            0.0,
            1.0
        ]
    },
    "numerical_method": {
        "viscous_operator_type": "DeviatoricSymmetric",
        "element_spaces": {
            "k_velocity": 2,
            "k_pressure": 1
        },
        "stabilization": {
            "method": "ASGS"
        },
        "solver": {
            "picard_iterations": 5,
            "dynamic_picard_re_threshold": 10000.0,
            "dynamic_picard_re_iterations": 15,
            "dynamic_picard_da_threshold": 10000.0,
            "dynamic_picard_da_iterations": 10,
            "newton_iterations": 20,
            "dynamic_newton_re_threshold": 10000.0,
            "dynamic_newton_re_iterations": 60,
            "ftol": 1e-8,
            "picard_ftol": 1e-3,
            "dynamic_ftol_ceiling": 1e-4,
            "dynamic_ftol_spatial_safety_factor": 1e-2,
            "xtol": 1e-8,
            "eps_tol_momentum": 1e-6,
            "eps_tol_mass": 0.8,
            "max_increases": 2,
            "freeze_jacobian_cusp": false,
            "linesearch_alpha_min": 1e-4,
            "armijo_c1": 1e-4,
            "divergence_merit_factor": 1.05,
            "stagnation_noise_floor": 1e-2,
            "condition_noise_floor_baseline": 1e-16,
            "condition_noise_floor_absolute_min": 1e-8,
            "condition_noise_floor_safety_factor": 10.0,
            "noise_floor_success_max_ftol_multiple": 1e30,
            "max_linesearch_iterations": 15,
            "linesearch_contraction_factor": 0.5,
            "run_diagnostics": false,
            "ablation_mode": "full",
            "experimental_reaction_mode": "standard",
            "newton_stall_window": 0,
            "newton_stall_min_rel_improvement": 0.0,
            "pingpong_enabled": false,
            "pingpong_max_swaps": 0,
            "pingpong_picard_gain_orders": 1.5,
            "newton_residual_divergence_patience": 0,
            "linear_solver": {
                "method": "LU",
                "ilu_drop_tolerance": 1e-4,
                "gmres_restart": 30,
                "gmres_rel_tol": 1e-11,
                "gmres_maxiter": 300
            }
        },
        "mesh": {
            "partition": [
                20,
                20
            ],
            "convergence_partitions": [
                10,
                20,
                30
            ],
            "element_type": "QUAD"
        }
    },
    "output": {
        "directory": "results",
        "basename": "porous_ns"
    }
}